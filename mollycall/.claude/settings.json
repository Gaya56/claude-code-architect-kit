{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(python -m pytest*)",
      "Bash(python3 -m pytest*)",
      "Bash(python3 .claude/scripts/workflow_gate.py*)",
      "Bash(python3 .claude/scripts/supabase_change_gate.py*)",
      "Bash(python3 .claude/scripts/supabase_validation_context.py*)",
      "Bash(python3 -m py_compile*)",
      "Bash(railway link*)",
      "Bash(railway logs*)",
      "Bash(railway status*)"
    ],
    "deny": [
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {},
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "railway@claude-plugins-official": true
  }
}
